# PostgreSQL Configuration
POSTGRES_DB=ai_calendar_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<GENERATE_A_STRONG_PASSWORD>
POSTGRES_PORT=5432

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=<GENERATE_A_STRONG_PASSWORD>
PGADMIN_PORT=5050

# Application Configuration
# SECURITY: Never commit actual secrets to version control
# Use environment variables or a secrets manager in production

# Database Connection (required)
DATABASE_URL=postgresql://postgres:<PASSWORD>@localhost:5432/ai_calendar_manager

# Google OAuth Configuration (required)
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
GOOGLE_REDIRECT_URI=http://localhost:5047/api/auth/callback

# Encryption Key for OAuth Tokens (required)
# Generate using: dotnet run --project KeyGenerator
ENCRYPTION_KEY=<BASE64_ENCODED_32_BYTE_KEY>

# Claude API Configuration (optional - enables AI features)
CLAUDE_API_KEY=<YOUR_CLAUDE_API_KEY>

# Frontend URL for OAuth redirects (optional)
FRONTEND_URL=http://localhost:4200